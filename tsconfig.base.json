{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ESNext"],
    "types": ["node"],

    "strict": true,
    "verbatimModuleSyntax": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    // "outDir": "./dist",
    // "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    "skipLibCheck": true,
    "incremental": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "plugins": [{
      "transform": "@sora-soft/type-guard/dist/transformer"
    }, {
      "transform": "../../transformer/VersionTransformer.cjs"
    }]
  }
}
