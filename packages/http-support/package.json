{
  "name": "@sora-soft/http-support",
  "version": "2.0.2",
  "description": "sora system http support",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "npm run clean && tspc",
    "clean": "rimraf ./dist",
    "prepublishOnly": "tspc",
    "prepare": "ts-patch install -s",
    "lint": "eslint src/",
    "preversion": "eslint src/ && npm run build"
  },
  "repository": "git@github.com:sora-soft/sora-monorepo.git",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./koa": {
      "import": "./dist/koa.js",
      "types": "./dist/koa.d.ts"
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "sora",
    "http"
  ],
  "author": "yaya",
  "license": "WTFPL",
  "bugs": {
    "url": "https://github.com/sora-soft/sora-monorepo/issues"
  },
  "homepage": "https://github.com/sora-soft/sora-monorepo",
  "devDependencies": {
    "@types/cookie": "^1.0.0",
    "@types/koa": "^2.15.0",
    "@types/uuid": "^8.3.0",
    "@types/ws": "^8.2.2",
    "@types/qs": "^6.9.0",
    "rimraf": "^3.0.2",
    "ts-patch": "^3.3.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@sora-soft/framework": "workspace:*",
    "@sora-soft/typia-decorator": "workspace:*",
    "axios": "^1.15.0",
    "cookie": "^1.1.1",
    "fast-xml-parser": "^4.4.0",
    "koa": "^2.13.1",
    "qs": "^6.15.1",
    "raw-body": "^3.0.2",
    "uuid": "^8.3.2",
    "ws": "^8.4.2"
  }
}
