{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "plugins": [
      { "transform": "typia/lib/transform" },
      { "transform": "../../scripts/version-transform", "identifier": "__VERSION__" }
