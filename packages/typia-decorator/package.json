{
  "name": "@sora-soft/typia-decorator",
  "version": "2.1.0",
  "description": "AOT parameter type validation via @guard decorator and TypeScript AST Transformer, powered by typia",
  "type": "module",
  "main": "./dist/runtime/index.js",
  "types": "./dist/runtime/index.d.ts",
  "exports": {
    ".": "./dist/runtime/index.js",
    "./runtime": "./dist/runtime/index.js",
    "./transform": "./dist/transform/index.js",
    "./unplugin": "./dist/unplugin/index.js",
    "./unplugin/vite": "./dist/unplugin/vite.js",
    "./unplugin/esbuild": "./dist/unplugin/esbuild.js"
  },
  "scripts": {
    "build": "rimraf ./dist && tsc --project ./src/runtime/tsconfig.json && tsc --project ./src/transform/tsconfig.json && tsc --project ./src/unplugin/tsconfig.json && copyfiles -f ./src/transform/package.json ./dist/transform",
    "clean": "rimraf ./dist",
    "prepublishOnly": "npm run build",
    "lint": "eslint src/"
  },
  "repository": "git@github.com:sora-soft/sora-node.git",
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "sora",
    "typia",
    "decorator",
    "validation",
    "aot",
    "transformer"
  ],
  "author": "yaya",
  "license": "WTFPL",
  "bugs": {
    "url": "https://github.com/sora-soft/sora-node/issues"
  },
  "homepage": "https://github.com/sora-soft/sora-node",
  "peerDependencies": {
    "@rollup/pluginutils": "^5.0.0",
    "@typia/core": "^12.0.0",
    "consola": "^3.0.0",
    "diff-match-patch-es": "^1.0.0",
    "find-cache-dir": "^5.0.0",
    "magic-string": "^0.30.0",
    "pathe": "^2.0.0",
    "pkg-types": "^1.0.0",
    "typescript": "^5.0.0",
    "typia": "^12.0.0",
    "unplugin": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@typia/core": "^12.0.0",
    "copyfiles": "^2.4.1",
    "rimraf": "^3.0.2",
    "typescript": "^5.9.3",
    "@typia/unplugin": "^12.0.2"
  }
}
