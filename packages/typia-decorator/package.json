{
  "name": "@sora-soft/typia-decorator",
  "version": "2.0.2",
  "description": "AOT parameter type validation via @guard decorator and TypeScript AST Transformer, powered by typia",
  "type": "module",
  "main": "./dist/runtime/index.js",
  "types": "./dist/runtime/index.d.ts",
  "exports": {
    ".": "./dist/runtime/index.js",
    "./runtime": "./dist/runtime/index.js",
    "./transform": "./dist/transform/index.js"
  },
  "scripts": {
    "build": "rimraf ./dist && tsc --project ./src/runtime/tsconfig.json && tsc --project ./src/transform/tsconfig.json && copyfiles -f ./src/transform/package.json ./dist/transform",
    "clean": "rimraf ./dist",
    "prepublishOnly": "npm run build",
    "lint": "eslint src/"
  },
  "repository": "git@github.com:sora-soft/sora-monorepo.git",
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "sora",
    "typia",
    "decorator",
    "validation",
    "aot",
    "transformer"
  ],
  "author": "yaya",
  "license": "WTFPL",
  "bugs": {
    "url": "https://github.com/sora-soft/sora-monorepo/issues"
  },
  "homepage": "https://github.com/sora-soft/sora-monorepo",
  "peerDependencies": {
    "@typia/core": "^12.0.0",
    "typescript": "^5.0.0",
    "typia": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@typia/core": "^12.0.0",
    "copyfiles": "^2.4.1",
    "rimraf": "^3.0.2",
    "typescript": "^5.9.3"
  }
}
