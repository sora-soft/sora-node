{
  "name": "@sora-soft/type-guard",
  "version": "2.0.1",
  "description": "sora system type guard",
  "main": "./dist/runtime/index.js",
  "types": "./dist/runtime/index.d.ts",
  "scripts": {
    "build": "rimraf ./dist && tsc --project ./src/runtime/tsconfig.json && tsc --project ./src/transformer/tsconfig.json && copyfiles -f ./src/transformer/package.json ./dist/transformer",
    "clean": "rimraf ./dist",
    "prepublishOnly": "npm run build",
    "lint": "eslint",
    "preversion": "eslint && npm run build"
  },
  "repository": "git@github.com:sora-soft/type-guard.git",
  "type": "module",
  "exports": {
    ".": "./dist/runtime/index.js",
    "./transformer": "./dist/transformer/index.js",
    "./dist/transformer": "./dist/transformer/index.js"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "sora",
    "type-guard"
  ],
  "author": "yaya",
  "license": "WTFPL",
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@stylistic/eslint-plugin-ts": "^4.4.1",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^24.0.0",
    "@types/object-hash": "^3.0.6",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "copyfiles": "^2.4.1",
    "eslint": "^9.39.4",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "rimraf": "^3.0.2"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "json-schema": "^0.4.0",
    "object-hash": "^3.0.0",
    "path-equal": "^1.1.2",
    "reflect-metadata": "^0.2.2",
    "source-map-support": "^0.5.21"
  }
}
