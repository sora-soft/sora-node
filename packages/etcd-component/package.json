  "devDependencies": {
    "@swc/core": "^1.15.30",
    "rimraf": "^3.0.2",
    "typescript": "^5.9.3",
    "vite": "^7.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-swc-transform": "^1.1.1"
  },
  "dependencies": {
    "@sora-soft/framework": "workspace:*",
