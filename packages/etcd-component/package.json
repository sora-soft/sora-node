  "description": "sora system etcd component",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "npm run clean && vite build",
    "clean": "rimraf ./dist",
    "prepublishOnly": "vite build",
    "lint": "eslint src/",
    "preversion": "eslint src/ && npm run build"
  },
  "repository": "git@github.com:sora-soft/sora-node.git",
