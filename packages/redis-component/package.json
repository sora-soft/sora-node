{
  "name": "@sora-soft/redis-component",
  "version": "2.1.0",
  "description": "sora system redis component",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "npm run clean && tsc",
    "clean": "rimraf ./dist",
    "prepublishOnly": "tsc",
    "lint": "eslint src/",
    "preversion": "eslint src/ && npm run build"
  },
  "repository": "git@github.com:sora-soft/sora-node.git",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./redis": {
      "import": "./dist/redis.js",
      "types": "./dist/redis.d.ts"
    },
    "./redlock": {
      "import": "./dist/redlock.js",
      "types": "./dist/redlock.d.ts"
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "sora",
    "redis"
  ],
  "author": "yaya",
  "license": "WTFPL",
  "bugs": {
    "url": "https://github.com/sora-soft/sora-node/issues"
  },
  "homepage": "https://github.com/sora-soft/sora-node",
  "devDependencies": {
    "@types/redlock": "^4.0.4",
    "rimraf": "^3.0.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@sora-soft/framework": "workspace:*",
    "@sora-soft/typia-decorator": "workspace:*",
    "redis": "^4.6.5",
    "redlock": "^4.2.0"
  }
}
