{
  "name": "@sora-soft/framework",
  "version": "2.1.0",
  "description": "sora system framework project",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "npm run clean && tsc",
    "clean": "rimraf ./dist",
    "prepublishOnly": "tsc",
    "lint": "eslint src/",
    "preversion": "eslint src/ && npm run build",
    "build:test": "tsc -p tsconfig.test.json",
    "test": "npm run build:test && node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "test:only": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js"
  },
  "repository": "git@github.com:sora-soft/sora-node.git",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./rxjs": {
      "import": "./dist/rxjs.js",
      "types": "./dist/rxjs.d.ts"
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "sora",
    "frame"
  ],
  "author": "yaya",
  "license": "WTFPL",
  "bugs": {
    "url": "https://github.com/sora-soft/sora-node/issues"
  },
  "homepage": "https://github.com/sora-soft/sora-node",
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@stylistic/eslint-plugin-ts": "^4.4.1",
    "@types/node": "^24.0.0",
    "@types/uuid": "^8.3.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^9.39.4",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jest": "^30.3.0",
    "rimraf": "^3.0.2",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@sora-soft/typia-decorator": "workspace:*",
    "chalk": "^5.6.2",
    "error-stack-parser": "^2.0.6",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0",
    "typia": "^12.0.2",
    "uuid": "^8.3.2"
  }
}
