{
  "name": "@sora-soft/sora-cli",
  "version": "2.0.0",
  "description": "sora system cli tool",
  "bin": {
    "sora": "./bin/cli.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "npm run clean && tsc",
    "clean": "rimraf ./dist",
    "prepublishOnly": "npm run clean && tsc",
    "lint": "eslint src/"
  },
  "keywords": [
    "sora",
    "cli"
  ],
  "author": "yaya",
  "license": "WTFPL",
  "files": [
    "/bin",
    "/dist",
    "/template"
  ],
  "oclif": {
    "commands": "./dist/commands",
    "bin": "sora",
    "plugins": [
      "@oclif/plugin-help"
    ]
  },
  "dependencies": {
    "@oclif/command": "^1.8.36",
    "@oclif/config": "^1.18.17",
    "@oclif/errors": "^1.3.6",
    "@oclif/help": "^1.0.1",
    "@oclif/plugin-help": "^6.2.44",
    "@types/js-yaml": "^4.0.9",
    "art-template": "^4.13.2",
    "camelcase": "^6.2.0",
    "chalk": "^4.1.2",
    "inquirer": "^8.0.0",
    "isomorphic-git": "^1.21.0",
    "js-yaml": "^4.1.1",
    "mkdirp": "^0.5.5",
    "ora": "^5.4.0",
    "source-map-support": "^0.5.19"
  },
  "devDependencies": {
    "@types/inquirer": "^7.3.1",
    "@types/mkdirp": "^1.0.1",
    "@types/node": "^24.0.0",
    "rimraf": "^3.0.2",
    "typescript": "~5.9.3"
  }
}
