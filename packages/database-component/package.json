{
  "name": "@sora-soft/database-component",
  "version": "1.6.3",
  "description": "sora system database component",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "npm run clean && tspc",
    "clean": "rimraf ./dist",
    "prepublishOnly": "tspc",
    "prepare": "ts-patch install -s",
    "lint": "eslint",
    "preversion": "eslint && npm run build"
  },
  "repository": "git@github.com:sora-soft/database-component.git",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./typeorm": {
      "import": "./dist/typeorm.js",
      "types": "./dist/typeorm.d.ts"
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "sora",
    "database"
  ],
  "author": "yaya",
  "license": "WTFPL",
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@stylistic/eslint-plugin-ts": "^4.4.1",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^9.39.4",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "rimraf": "^3.0.2",
    "ts-patch": "^3.3.0"
  },
  "dependencies": {
    "@sora-soft/framework": "workspace:*",
    "@sora-soft/type-guard": "workspace:*",
    "mysql2": "^2.2.5",
    "reflect-metadata": "^0.1.13",
    "typeorm": "^0.3.11"
  }
}
