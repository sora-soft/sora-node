{
  "name": "@sora-soft/database-component",
  "version": "2.1.0",
  "description": "sora system database component",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "npm run clean && tsc",
    "clean": "rimraf ./dist",
    "prepublishOnly": "tsc",
    "lint": "eslint src/",
    "preversion": "eslint src/ && npm run build"
  },
  "repository": "git@github.com:sora-soft/sora-node.git",
  "type": "module",
  "exports": {
