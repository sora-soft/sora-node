  "devDependencies": {
    "rimraf": "^3.0.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@sora-soft/framework": "workspace:*",
    "@sora-soft/typia-decorator": "workspace:*",
    "mysql2": "^2.2.5",
    "reflect-metadata": "^0.1.13",
    "typeorm": "^0.3.11"
