{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "Node16",
    "moduleResolution": "Node16",
    "verbatimModuleSyntax": false,
    "emitDecoratorMetadata": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "plugins": []
  },
  "include": ["src/**/*"]
}
