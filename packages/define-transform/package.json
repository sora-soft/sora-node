{
  "name": "@sora-soft/define-transform",
  "version": "2.2.0",
  "description": "Compile-time constant injection transformer for ts-patch, supports pkg/env/literal sources",
  "type": "commonjs",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./transform": "./dist/index.js"
  },
  "scripts": {
    "build": "rimraf ./dist && tsc",
    "clean": "rimraf ./dist",
    "prepublishOnly": "npm run build",
    "lint": "eslint src/"
  },
  "repository": "git@github.com:sora-soft/sora-node.git",
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "sora",
    "typescript",
    "transformer",
    "ts-patch",
    "compile-time",
    "define"
  ],
  "author": "yaya",
  "license": "WTFPL",
  "bugs": {
    "url": "https://github.com/sora-soft/sora-node/issues"
  },
  "homepage": "https://github.com/sora-soft/sora-node",
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "rimraf": "^3.0.2",
    "typescript": "^5.9.3"
  }
}
